<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DayCare.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DayCare.Views"
    Shell.NavBarIsVisible="True">

    <!-- Settings gear icon top right -->
    <Shell.ToolbarItems>
        <ToolbarItem
            IconImageSource="gear_icon.png"
            Order="Primary"
            Priority="0"
            Clicked="OnSettingsClicked" />
    </Shell.ToolbarItems>

    <TabBar>
        <Tab Title="Pick Up/Drop Off" Icon="pickup_icon.png">
            <ShellContent
                x:Name="PickupDropoffContent"
                Title="Pick Up/Drop Off"
                Route="PickupDropoff" />
        </Tab>

        <Tab Title="Feed" Icon="feed_icon.png">
            <ShellContent
                x:Name="FeedContent"
                Title="Feed"
                Route="Feed" />
        </Tab>

        <Tab Title="Billing" Icon="billing_icon.png">
            <ShellContent
                x:Name="BillingContent"
                Title="Billing"
                Route="Billing" />
        </Tab>
    </TabBar>

</Shell>
