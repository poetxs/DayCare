<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors – Bright Pastels -->
    <Color x:Key="Primary">#7EB3FF</Color>          <!-- Pastel Blue -->
    <Color x:Key="PrimaryDark">#5C9AFF</Color>
    <Color x:Key="PrimaryLight">#D4E6FF</Color>
    <Color x:Key="Secondary">#7ED67E</Color>         <!-- Pastel Green -->
    <Color x:Key="Accent">#FF7E7E</Color>            <!-- Pastel Red -->
    <Color x:Key="AccentYellow">#FFE57E</Color>      <!-- Pastel Yellow -->

    <!-- Semantic Colors -->
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="SuccessBackground">#DCFCE7</Color>
    <Color x:Key="Error">#DC2626</Color>
    <Color x:Key="ErrorBackground">#FEE2E2</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="WarningBackground">#FEF3C7</Color>

    <!-- Neutral Colors -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>

</ResourceDictionary>
